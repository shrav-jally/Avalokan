# Backend environment variables

# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# Frontend URL used for OAuth redirect after login
FRONTEND_URL=http://localhost:5173

# CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth (required for /login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin allowlist (comma-separated emails)
ADMIN_ALLOWLIST=shravya.jallepally@gmail.com,test@example.com,admin@avalokan.gov
